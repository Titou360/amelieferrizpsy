# MongoDB
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/amelie-ferriz

# JWT secret (générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=VOTRE_SECRET_JWT_TRES_LONG

# Mot de passe admin hashé (générer avec le script setup-password.js)
ADMIN_PASSWORD_HASH=VOTRE_HASH_BCRYPT

# SMTP (pour le formulaire de contact)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_app_password

# Email de destination pour les messages de contact
CONTACT_EMAIL=contact@amelieferriz.fr

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:5173

# En production:
# PORT=3001
